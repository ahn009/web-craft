generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String
  password  String
  purchases Purchase[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Agent {
  id          String     @id @default(cuid())
  workflowId  String     @unique
  name        String
  description String
  category    String
  price       Float
  tags        String     @default("[]")
  nodeCount   Int
  rawJson     String
  purchases   Purchase[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  amount    Float
  user      User     @relation(fields: [userId], references: [id])
  agent     Agent    @relation(fields: [agentId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, agentId])
}
