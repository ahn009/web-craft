# Database
DATABASE_URL=postgresql://webcraft:webcraft_secret@localhost:5432/webcraft

# JWT
JWT_SECRET=change-me-to-a-random-secret
CREDENTIAL_ENCRYPTION_KEY=change-me-credential-key-32-bytes

# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
ENABLE_TEST_ROUTES=false
CHECKOUT_MODE=demo
ADMIN_EMAIL=admin@webcraft.ai
EXECUTION_MAX_ACTIVE_PER_USER=10
EXECUTION_MAX_OUTPUT_BYTES=1000000

# Frontend
# Leave empty for same-origin Docker/production serving. Use http://localhost:3000 when running Vite separately.
VITE_API_URL=http://localhost:3000

# Workflow data
ZIP_PATH=../n8n-workflow-templates-main.zip

# Hosted execution / n8n
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_TIMEOUT_MS=15000
N8N_ENCRYPTION_KEY=change-me-n8n-encryption-key

# SendGrid (optional - emails log to console if not set)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@webcraft.ai
